{
  "name": "micall-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "MiCall 用户端 H5 生产前端：DC 原型逐像素复刻，mock 替换为服务端信令",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "smoke": "tsx scripts/smoke.tsx",
    "lint:bindings": "tsx scripts/lint-bindings.tsx",
    "test": "tsx scripts/smoke.tsx && tsx scripts/lint-bindings.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
