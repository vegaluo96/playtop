# SQLite 数据库文件路径（默认 ./data/app.db，部署时建议挂载持久卷）
DATABASE_PATH=./data/app.db

# session 相关密钥（生产环境必须改为随机长串）
SESSION_SECRET=change-me-in-production

# ===== 以下仅测试/模拟用，生产环境不要设置 =====
# 固定"当前时间"（epoch 毫秒），供端到端模拟推进时间
# FAKE_NOW=
# DATASOURCE=fixture 时数据采集从 tests/fixtures 读取假数据
# DATASOURCE=
# LLM=mock 时报告定性段落返回固定文案，不调 apiyi
# LLM=
