# API-Football v3（api-sports.io）密钥——数据层唯一外部依赖
# 生产：写入 /srv/playtop.env（不入仓库）；本地开发可复制为 .env.local
API_FOOTBALL_KEY=

# SQLite 路径（node:sqlite，Node ≥22.5；默认 data/playtop.db）
PLAYTOP_DB=data/playtop.db

# worker 抓取的联赛（AF league id，默认 英超/西甲/德甲/意甲/法甲/欧冠/欧联/世界杯）
FOLLOWED_LEAGUES=39,140,78,135,61,2,3,1

# worker 相邻出网调用最小间隔毫秒（免费套餐建议 7000）
AF_DELAY_MS=300
