# SQLite 数据库文件路径（默认 ./data/app.db，部署时建议挂载持久卷）
DATABASE_PATH=./data/app.db

# 会话 cookie 安全：生产环境（NODE_ENV=production）自动开启 secure；
# 若在 HTTPS 反代后仍需强制可设 COOKIE_SECURE=1
# COOKIE_SECURE=1

# 首次启动自举的管理员账号（务必覆盖默认 admin/admin123456）
# ADMIN_USERNAME=
# ADMIN_PASSWORD=

# API-Football 付费主源 key（也可在后台 系统设置→数据源 填写，后台优先）
# API_FOOTBALL_KEY=

# ===== 以下仅测试/模拟用，生产环境不要设置 =====
# 固定"当前时间"（epoch 毫秒），供端到端模拟推进时间
# FAKE_NOW=
# LLM=mock 时报告定性段落返回固定文案，不调 apiyi
# LLM=
